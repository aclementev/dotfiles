# Theme
theme = iTerm2 Solarized Light
# theme = tokyonight-storm

# Font
font-family = JetBrainsMono Nerd Font Mono
font-style = Medium
font-size = 12

# Cursor
cursor-style = block
cursor-style-blink = false
# This makes it so that the shell (zsh/bash) do not override the cursor setting for Ghostty
shell-integration-features = no-cursor
keybind = shift+enter=text:\x1b\r
# Workaround for the issue with Zoom In keybind
keybind = cmd+equal=unbind
keybind = cmd+==increase_font_size:1

# Enable URL <CMD+Click>
link-url = true

# Free Alt-<h/j/k/l> keymaps to be used inside applications (e.g. neovim)
keybind = alt+h=unbind
keybind = alt+l=unbind
keybind = alt+j=unbind
keybind = alt+k=unbind

# Decorations
macos-titlebar-style = transparent
